# Copy this file to ".env" and fill in your values.
# cp .env.example .env

# ---------------------------------------------------------------------------
# LLM (OpenAI-compatible). The only external service this app talks to.
# Works with official OpenAI, Azure OpenAI, or any OpenAI-style gateway
# (Ollama, LM Studio, vLLM, third-party proxies...).
# ---------------------------------------------------------------------------

# Base URL of the OpenAI-compatible API.
#   Official OpenAI : https://api.openai.com/v1
#   Ollama (local)  : http://localhost:11434/v1
#   LM Studio       : http://localhost:1234/v1
LLM_BASE_URL=https://api.openai.com/v1

# API key. Use any non-empty placeholder for local servers that ignore it.
LLM_API_KEY=sk-your-key-here

# Chat model id.
LLM_MODEL=gpt-4o-mini

# Optional: a faster / non-thinking model for the background substitution-matrix
# refresh (defaults to LLM_MODEL). Set this when LLM_MODEL is a slow reasoning
# model — e.g. deepseek-chat when LLM_MODEL is deepseek-v4-pro.
# LLM_REFRESH_MODEL=deepseek-chat

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
# Host 0.0.0.0 binds to all interfaces so phones on the LAN can reach the app.
HOST=0.0.0.0
PORT=8000

# Optional: override where recipe Markdown lives (defaults to ./data).
# DATA_DIR=./data
